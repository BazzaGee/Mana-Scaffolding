  phone: '0508 626 272',
  email: 'terry@manascaffolding.co.nz',
  address: {
    street: '65c Highsted Road, Bishopdale',
    city: 'Christchurch',
    region: 'Canterbury',
    postcode: '8053',
    country: 'New Zealand'
  }
};

const stats = [
  { number: '500+', label: 'Projects Completed' },
  { number: '0', label: 'Safety Incidents' },
  { number: '7', label: 'Years Operating' },
  { number: '100%', label: 'Canterbury Owned' },
];

const teamMembers = [
  {
    name: 'Terry Pohatu',
    role: 'Founder & Director',
    expertise: 'Canada Expertise',
    quote: 'We bring North American industrial rigging protocols to New Zealand\'s unique topographical challenges.',
