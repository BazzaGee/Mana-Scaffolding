---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found" description="The page you're looking for doesn't exist" hideSidebar={true}>
  <main id="main-content" class="min-h-screen flex items-center justify-center">
    <div class="container mx-auto px-6 text-center py-32">
      <div class="max-w-2xl mx-auto">
        <div class="inline-flex items-center gap-3 border border-primary/30 bg-primary/10 px-4 py-2 mb-8">
          <span class="text-label-xs font-headline font-black text-primary uppercase tracking-widest">Error 404</span>
        </div>
        
        <h1 class="text-6xl md:text-8xl font-headline font-black uppercase tracking-tighter text-white mb-6">
          <span class="text-primary">404</span>
        </h1>
        
        <h2 class="text-2xl md:text-4xl font-headline font-black uppercase tracking-tight text-white mb-4">
          This Path Needs Scaffolding
        </h2>
        
        <div class="h-[2px] w-16 bg-primary mx-auto mb-8"></div>
        
        <p class="text-zinc-400 text-lg md:text-xl leading-relaxed mb-12 max-w-lg mx-auto">
          The page you're looking for doesn't exist or has been moved. Let's get you back on solid ground.
        </p>
        
        <div class="scaffolding-grid-bg absolute inset-0 pointer-events-none opacity-30"></div>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center relative z-10">
          <a 
            href="/" 
            class="inline-flex items-center justify-center bg-primary text-white font-headline font-bold uppercase whitespace-nowrap px-8 md:px-10 py-4 text-sm md:text-base tracking-wider transition-all duration-300 hover:bg-orange-600 border-b-4 border-orange-800 shadow-[0_4px_20px_rgba(212,68,28,0.4)]"
          >
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4 md:w-5 md:h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
              </svg>
              Back to Home
            </span>
          </a>
          <a 
            href="/contact"
            class="inline-flex items-center justify-center border-2 border-white/50 text-white font-headline font-bold uppercase whitespace-nowrap px-8 md:px-10 py-4 text-sm md:text-base tracking-wider transition-all duration-300 hover:bg-white hover:text-black hover:border-white"
          >
            <span class="flex items-center gap-2">
              Contact Us
              <svg class="w-4 h-4 md:w-5 md:h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/>
              </svg>
            </span>
          </a>
        </div>
        
        <div class="mt-16 flex justify-center gap-8">
          <a href="/services" class="text-zinc-500 hover:text-primary transition-colors text-sm font-headline font-bold uppercase tracking-widest">Services</a>
          <a href="/locations" class="text-zinc-500 hover:text-primary transition-colors text-sm font-headline font-bold uppercase tracking-widest">Locations</a>
          <a href="/blog" class="text-zinc-500 hover:text-primary transition-colors text-sm font-headline font-bold uppercase tracking-widest">Blog</a>
        </div>
      </div>
    </div>
  </main>
</Base>
