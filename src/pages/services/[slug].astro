---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.id.replace(/\.md$/, '') },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);

const serviceImages = {
  'residential-scaffolding': '/images/Mana facebook pic.jpg',
  'commercial-scaffolding': '/images/Mana facebook pic2.jpg',
  'industrial-scaffolding': '/images/Mana-Scaffolding-trucks-at-work.jpg',
  'complex-access-solutions': '/images/N3.jpg',
};

const defaultImage = '/images/N1.jpg';
const heroImage = serviceImages[service.id.replace(/\.md$/, '')] || defaultImage;
---

<Base title={service.data.title} description={service.data.description}>
  <main id="main-content" class="pt-24 pb-16">
    <!-- Hero Section with Image Background -->
    <section class="relative py-20 md:py-28 bg-zinc-950">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/90 to-zinc-950/50 z-10"></div>
        <img 
          src={heroImage} 
          alt={service.data.title} 
          class="w-full h-full object-cover opacity-30"
          loading="lazy"
        />
      </div>
      <div class="container mx-auto px-6 relative z-20">
        <div class="max-w-4xl reveal-on-scroll">
          <div class="inline-flex items-center gap-2 bg-primary/10 border border-primary/30 px-4 py-2 mb-6">
            <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-4 6h-4v2h4v-2zM5 19V5h14v14H5zm2-8h10v2H7v-2z"/>
            </svg>
            <span class="text-label-xs font-bold text-primary uppercase tracking-widest">{service.data.service_type || 'Service'}</span>
          </div>
          <h1 class="text-3xl md:text-5xl lg:text-6xl font-headline font-black uppercase tracking-tighter text-white mb-6">
            {service.data.title}
          </h1>
          <p class="text-lg md:text-xl text-zinc-400 leading-relaxed mb-8 max-w-2xl">
            {service.data.description}
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a 
              href="/contact" 
              class="inline-flex items-center justify-center bg-primary text-white font-headline font-bold uppercase px-8 py-4 tracking-wider hover:bg-orange-600 transition-colors border-b-4 border-orange-800"
            >
              Get a Quote
            </a>
            <a 
              href="tel:0508626272" 
              class="inline-flex items-center justify-center border-2 border-white/30 text-white font-headline font-bold uppercase px-8 py-4 tracking-wider hover:bg-white hover:text-black transition-colors"
            >
              Call 0508 626 272
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Main Content -->
    <section class="py-16 bg-background">
      <div class="container mx-auto px-6 max-w-4xl">
        <div class="prose prose-invert prose-lg max-w-none reveal-on-scroll">
          <Content />
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="py-16 bg-surface border-t border-white/5">
      <div class="container mx-auto px-6">
        <div class="grid md:grid-cols-3 gap-8 reveal-on-scroll">
          <div class="bg-zinc-950 border border-white/5 p-8">
            <div class="w-12 h-12 bg-primary/10 rounded-sm flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z"/>
              </svg>
            </div>
            <h3 class="text-xl font-headline font-black uppercase text-white mb-3">Fully Compliant</h3>
            <p class="text-zinc-500 text-sm">All work meets NZ health and safety regulations and building codes.</p>
          </div>
          <div class="bg-zinc-950 border border-white/5 p-8">
            <div class="w-12 h-12 bg-primary/10 rounded-sm flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
            </div>
            <h3 class="text-xl font-headline font-black uppercase text-white mb-3">Safety First</h3>
            <p class="text-zinc-500 text-sm">Zero incident commitment with comprehensive safety protocols.</p>
          </div>
          <div class="bg-zinc-950 border border-white/5 p-8">
            <div class="w-12 h-12 bg-primary/10 rounded-sm flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
              </svg>
            </div>
            <h3 class="text-xl font-headline font-black uppercase text-white mb-3">Fast Quote</h3>
            <p class="text-zinc-500 text-sm">Get a detailed quotation within 24 hours of your inquiry.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 md:py-24 bg-background border-t border-white/5">
      <div class="container mx-auto px-6 text-center">
        <div class="reveal-on-scroll">
          <h2 class="text-3xl md:text-5xl font-headline font-black uppercase text-white mb-6">
            Ready to Start Your <span class="text-primary">Project</span>?
          </h2>
          <p class="text-lg text-zinc-400 mb-10 max-w-2xl mx-auto">
            Get a free technical consultation and quote for your {service.data.service_type?.toLowerCase() || 'scaffolding'} needs.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href="/contact" 
              class="bg-primary text-white font-headline font-bold uppercase px-8 py-4 tracking-wider hover:bg-orange-600 transition-colors border-b-4 border-orange-800"
            >
              Request Quote
            </a>
            <a 
              href="/services" 
              class="border-2 border-white/30 text-white font-headline font-bold uppercase px-8 py-4 tracking-wider hover:bg-white hover:text-black transition-colors"
            >
              View All Services
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
