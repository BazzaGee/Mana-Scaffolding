---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.id.replace(/\.md$/, '') },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);
const slug = service.id.replace(/\.md$/, '');
const type = service.data.service_type;

const serviceImages = {
  'residential-scaffolding': '/images/Mana facebook pic.jpg',
  'commercial-scaffolding': '/images/Mana facebook pic2.jpg',
  'industrial-scaffolding': '/images/Mana-Scaffolding-trucks-at-work.jpg',
  'complex-access-solutions': '/images/N3.jpg',
};
const defaultImage = '/images/N1.jpg';
const heroImage = serviceImages[slug] || defaultImage;
const ogImage = service.data.image || heroImage;
const canonicalURL = `https://mana-scaffolding.pages.dev/services/${slug}`;
const siteUrl = 'https://mana-scaffolding.pages.dev';

const serviceContent: Record<string, {
  tagline: string;
  features: { icon: string; title: string; desc: string }[];
  steps: { title: string; desc: string }[];
  stats: { value: string; label: string }[];
}> = {
  Residential: {
    tagline: 'Safe access for your biggest investment',
    features: [
      { icon: 'new-build', title: 'New Home Construction', desc: 'Multi-lift scaffolding from foundation to roof truss. Bricklayer platforms, finishing stages, and flexible modifications as your build progresses.' },
      { icon: 'renovation', title: 'Renovations & Additions', desc: 'Second-story additions, re-cladding, structural repairs, and window replacement. Engineered access for every phase of your renovation.' },
      { icon: 'maintenance', title: 'Maintenance & Painting', desc: 'Roof work, exterior painting, gutter and fascia access. Quick-install systems for short-duration maintenance projects.' },
      { icon: 'heritage', title: 'Heritage Restoration', desc: 'Non-invasive support systems for character and protected homes. Sympathetic access that preserves historic fabric.' },
      { icon: 'shield', title: 'Property Protection', desc: 'Padded contact points, surface protection, landscaping consideration. Your home stays untouched around the work zone.' },
      { icon: 'schedule', title: 'Flexible Scheduling', desc: 'Work around your family life. Convenient timing, driveway access maintained where possible, minimal noise disruption.' },
    ],
    steps: [
      { title: 'Free Site Assessment', desc: 'We visit your property, evaluate site conditions, discuss access requirements, and provide a written quotation — all at no cost.' },
      { title: 'Custom Design', desc: 'Tailored configuration for your building geometry, neighbouring properties, and site constraints. Every setup is unique.' },
      { title: 'Professional Install', desc: 'Experienced Site Safe teams install your system with full safety protocols, tag systems, and user briefings.' },
      { title: 'Ongoing Support', desc: 'Inspection compliance maintained throughout. Modifications available if your project scope changes. One call does it all.' },
    ],
    stats: [
      { value: '500+', label: 'Homes Supported' },
      { value: '24hr', label: 'Quote Turnaround' },
      { value: '0', label: 'Safety Incidents' },
      { value: '100%', label: 'Compliance Rate' },
    ],
  },
  Commercial: {
    tagline: 'Engineered access for projects that can\'t wait',
    features: [
      { icon: 'building', title: 'Multi-Storey Access', desc: 'Full structural scaffolding for office towers, apartment complexes, and commercial builds. Façade installation through to final finish.' },
      { icon: 'tools', title: 'Building Maintenance', desc: 'Façade restoration, window cleaning systems, exterior upgrades, and ongoing maintenance access for occupied buildings.' },
      { icon: 'people', title: 'Public Protection', desc: 'Pedestrian gantries, debris shielding, signage coordination, and traffic management for street-facing commercial work.' },
      { icon: 'clock', title: 'Operational Continuity', desc: 'After-hours installation, tenant coordination, delivery route preservation. Your business keeps operating while we work.' },
      { icon: 'certificate', title: 'Engineering Certified', desc: 'Full design certification, producer statements, and loading calculations. Every system signed off by qualified engineers.' },
      { icon: 'project', title: 'Project Management', desc: 'Schedule integration, progress meetings, trade coordination, and rapid-response modifications. We work with your team.' },
    ],
    steps: [
      { title: 'Tender & Planning', desc: 'Early engagement at tender stage. Value engineering options, schedule integration, and risk assessment before work begins.' },
      { title: 'Engineering Design', desc: 'Load calculations, configuration optimization, and design certification coordinated with qualified structural engineers.' },
      { title: 'Installation & Compliance', desc: 'Professional setup with full documentation, permit applications, and inspection schedules. Ready for trade access.' },
      { title: 'Coordination & Support', desc: 'Multi-trade management, modifications on demand, and rapid issue resolution. A dedicated contact throughout.' },
    ],
    stats: [
      { value: '50+', label: 'Commercial Projects' },
      { value: '12hr', label: 'Mobilisation Time' },
      { value: '0', label: 'Safety Incidents' },
      { value: '100%', label: 'On Schedule' },
    ],
  },
  Industrial: {
    tagline: 'Heavy-duty access for demanding environments',
    features: [
      { icon: 'shutdown', title: 'Shutdown & Turnaround', desc: 'Rapid mobilisation for plant maintenance windows. Extended shift capability including 24/7 support and critical path scheduling.' },
      { icon: 'weight', title: 'Heavy-Duty Systems', desc: 'Engineered for extreme loads, equipment support, and harsh conditions. Reinforced components with full load verification.' },
      { icon: 'hazard', title: 'Hazardous Environments', desc: 'Chemical exposure protocols, temperature extremes, containment systems. Site-specific inductions and PPE compliance.' },
      { icon: 'tank', title: 'Confined Space Access', desc: 'Internal tank and vessel entry systems, limited-space solutions, and specialised training for restricted access scenarios.' },
      { icon: 'factory', title: 'Continuous Operations', desc: 'Integration with shift patterns, production scheduling, and isolation procedures. Your plant keeps running.' },
      { icon: 'alert', title: 'Emergency Deployment', desc: 'Urgent access needs handled fast. After-hours availability, critical path response, and immediate site assessment.' },
    ],
    steps: [
      { title: 'Hazard Assessment', desc: 'Comprehensive site evaluation including hazard identification, risk assessment, isolation coordination, and emergency planning.' },
      { title: 'Engineering Design', desc: 'Heavy-duty load calculations, equipment support specifications, and full engineering certification with producer statements.' },
      { title: 'Specialized Installation', desc: 'Hazard-trained teams implement containment, isolation compliance, and safety protocols. Full documentation supplied.' },
      { title: 'Operational Support', desc: 'Shift coordination, ongoing inspections, modification capability, and continuous compliance throughout your project.' },
    ],
    stats: [
      { value: '24/7', label: 'Availability' },
      { value: '48hr', label: 'Rapid Mobilisation' },
      { value: '0', label: 'Safety Incidents' },
      { value: '100%', label: 'Eng. Certified' },
    ],
  },
  Complex: {
    tagline: 'Engineering solutions for impossible access',
    features: [
      { icon: 'heritage-build', title: 'Heritage Structures', desc: 'Non-invasive access for protected buildings and historic sites. Heritage New Zealand compliant, reversible installation methods.' },
      { icon: 'cantilever', title: 'Cantilever Systems', desc: 'Counterweight and needle beam designs where ground support isn\'t possible. Engineered for specific loading conditions.' },
      { icon: 'suspended', title: 'Suspended Platforms', desc: 'Roof-mounted davit systems, swing stages, and multi-point suspension. Access from above when below is restricted.' },
      { icon: 'curve', title: 'Irregular Architecture', desc: 'Curved facades, complex geometries, multi-angle configurations. Segmented platforms that follow building form.' },
      { icon: 'bridge', title: 'Infrastructure Access', desc: 'Bridges, towers, domes, tanks, and non-building structures. Purpose-built systems for non-standard assets.' },
      { icon: 'ground', title: 'Environmental Challenges', desc: 'Over water, unstable ground, contaminated sites, archaeologically sensitive areas. Solutions that protect what\'s beneath.' },
    ],
    steps: [
      { title: 'Problem Analysis', desc: 'Constraint identification, stakeholder consultation, risk assessment, and solution exploration. We start by understanding the impossible.' },
      { title: 'Engineering Design', desc: 'Structural analysis, load calculations, connection design, and Heritage New Zealand compliance. Certified by qualified engineers.' },
      { title: 'Specialized Installation', desc: 'Expert installation teams with progressive verification and continuous monitoring. Adaptation capability throughout.' },
      { title: 'Verification & Handover', desc: 'Post-installation confirmation, compliance sign-off, stakeholder approvals, and comprehensive final reports.' },
    ],
    stats: [
      { value: '15+', label: 'Complex Projects' },
      { value: '3', label: 'Intl. Standards' },
      { value: '0', label: 'Safety Incidents' },
      { value: '100%', label: 'Eng. Certified' },
    ],
  },
};

const content = serviceContent[type] || serviceContent.Residential;

const iconMap: Record<string, string> = {
  'new-build': 'M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z',
  'renovation': 'M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3zm-2 10H8v-2h2v2zm4 0h-2v-2h2v2z',
  'maintenance': 'M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z',
  'heritage': 'M12 2L2 12h3v8h14v-8h3L12 2zm-2 10H8v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2zm-4 8h-2v-4h2v4z',
  'shield': 'M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z',
  'schedule': 'M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z',
  'building': 'M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z',
  'tools': 'M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z',
  'people': 'M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z',
  'clock': 'M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z',
  'certificate': 'M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z',
  'project': 'M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z',
  'shutdown': 'M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z',
  'weight': 'M12 3L2 12h3v8h14v-8h3L12 3zm5 15H7v-7.41l5-5 5 5V18zm-8-4h2v2H9v-2zm4 0h2v2h-2v-2z',
  'hazard': 'M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z',
  'tank': 'M20 2H4c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM8 20H4v-4h4v4zm0-6H4v-4h4v4zm0-6H4V4h4v4zm6 12h-4v-4h4v4zm0-6h-4v-4h4v4zm0-6h-4V4h4v4zm6 12h-4v-4h4v4zm0-6h-4v-4h4v4zm0-6h-4V4h4v4z',
  'factory': 'M22 22H2V10l7-3v3l7-3v3l7-3v15zm-9 0h2v-3h-2v3zm-4 0h2v-3h-2v3zm8 0h2v-3h-2v3z',
  'alert': 'M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z',
  'heritage-build': 'M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z',
  'cantilever': 'M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-4 6h-4v2h4v-2zM5 19V5h14v14H5zm2-8h10v2H7v-2z',
  'suspended': 'M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-4 6h-4v2h4v-2zM5 19V5h14v14H5zm2-8h10v2H7v-2z',
  'curve': 'M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-4 6h-4v2h4v-2zM5 19V5h14v14H5zm2-8h10v2H7v-2z',
  'bridge': 'M20 6h-4V4h-2v2h-2V4h-2v2H8V4H6v2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm0 14H4V8h16v12z',
  'ground': 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z',
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.data.title,
  description: service.data.description,
  url: canonicalURL,
  image: new URL(ogImage, siteUrl).href,
  provider: {
    '@type': 'Organization',
    name: 'Mana Scaffolding Limited',
    url: siteUrl,
    telephone: '0508626272',
    email: 'terry@manascaffolding.co.nz',
    address: { '@type': 'PostalAddress', addressLocality: 'Christchurch', addressRegion: 'Canterbury', addressCountry: 'NZ' },
  },
  areaServed: { '@type': 'Place', name: 'Christchurch, Canterbury, New Zealand' },
  serviceType: service.data.service_type,
  keywords: (service.data.keywords || []).join(', '),
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${siteUrl}/services` },
    { '@type': 'ListItem', position: 3, name: service.data.title, item: canonicalURL },
  ],
};

const faqJsonLd = (service.data.faq || []).length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: (service.data.faq || []).map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
} : null;
---

<Base title={service.data.title} description={service.data.description} image={ogImage} canonicalURL={canonicalURL}>
  <Fragment slot="head">
    {service.data.keywords && service.data.keywords.length > 0 && (
      <meta name="keywords" content={service.data.keywords.join(', ')} />
    )}
    <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
  </Fragment>

  <main id="main-content" class="pt-24 pb-16">
    <!-- Breadcrumbs -->
    <nav class="bg-zinc-950 border-b border-white/5" aria-label="Breadcrumb">
      <div class="container mx-auto px-6 py-4">
        <ol class="flex items-center gap-2 text-xs uppercase tracking-widest">
          <li><a href="/" class="text-zinc-500 hover:text-primary transition-colors">Home</a></li>
          <li class="text-zinc-600">/</li>
          <li><a href="/services" class="text-zinc-500 hover:text-primary transition-colors">Services</a></li>
          <li class="text-zinc-600">/</li>
          <li class="text-primary font-bold">{type}</li>
        </ol>
      </div>
    </nav>

    <!-- Hero -->
    <section class="relative py-20 md:py-28 bg-zinc-950">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/90 to-zinc-950/50 z-10"></div>
        <img src={heroImage} alt={service.data.title} class="w-full h-full object-cover opacity-30 scroll-color" loading="lazy" />
      </div>
      <div class="container mx-auto px-6 relative z-20">
        <div class="max-w-4xl">
          <div class="inline-flex items-center gap-2 bg-primary/10 border border-primary/30 px-4 py-2 mb-6">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
            </span>
            <span class="text-label-xs font-bold text-primary uppercase tracking-widest">{type} Services</span>
          </div>
          <h1 class="text-3xl md:text-5xl lg:text-6xl font-headline font-black uppercase tracking-tighter text-white mb-4">
            {service.data.title}
          </h1>
          <p class="text-lg md:text-xl text-primary font-headline font-bold mb-6">{content.tagline}</p>
          <p class="text-base md:text-lg text-zinc-400 leading-relaxed mb-8 max-w-2xl">
            {service.data.description}
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/contact" class="inline-flex items-center justify-center bg-primary text-white font-headline font-bold uppercase px-8 py-4 tracking-wider hover:bg-orange-600 transition-colors border-b-4 border-orange-800 shadow-[0_4px_20px_rgba(212,68,28,0.4)]">
              <span class="flex items-center gap-2">
                Get Your Free Quote
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 4l-1.41 1.41L16.17 11H4v2h12.17l-5.58 5.59L12 20l8-8z"/></svg>
              </span>
            </a>
            <a href="tel:0508626272" class="inline-flex items-center justify-center border-2 border-white/30 text-white font-headline font-bold uppercase px-8 py-4 tracking-wider hover:bg-white hover:text-black transition-colors">
              Call 0508 626 272
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Editorial Intro -->
    <section class="py-16 md:py-24 bg-background">
      <div class="container mx-auto px-6 md:px-12">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div class="relative">
            <div class="aspect-[4/3] bg-surface border border-white/5 p-2 overflow-hidden">
              <img alt={service.data.title} class="w-full h-full object-cover scroll-color" src={heroImage} loading="lazy" decoding="async" />
            </div>
            <div class="absolute -top-4 -right-4 w-24 h-24 border-t-2 border-r-2 border-primary"></div>
            <div class="absolute -bottom-4 -left-4 w-24 h-24 border-b-2 border-l-2 border-primary"></div>
          </div>
          <div class="reveal-on-scroll">
            <div class="flex items-center gap-4 mb-6">
              <div class="h-[2px] w-12 bg-primary"></div>
              <span class="text-primary font-headline font-black tracking-widest text-label-xs uppercase">{type} Expertise</span>
            </div>
            <div class="prose prose-invert prose-lg max-w-none">
              <Content />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- What We Deliver - Feature Cards -->
    <section class="py-16 md:py-24 bg-zinc-950">
      <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-16 reveal-on-scroll">
          <h2 class="text-4xl md:text-5xl font-headline font-black uppercase tracking-tighter text-white">What We <span class="text-primary">Deliver</span></h2>
          <p class="text-zinc-500 mt-4 uppercase tracking-[0.3em] font-headline text-label-xs font-bold">{type} Capabilities | Canterbury Wide</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 reveal-on-scroll">
          {content.features.map((feature, i) => (
            <div class="industrial-slab p-8 group bg-surface hover:bg-zinc-900 transition-all duration-300">
              <div class="flex justify-between items-start mb-6">
                <div class="w-12 h-12 bg-primary/10 rounded-sm flex items-center justify-center text-primary flex-shrink-0">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d={iconMap[feature.icon] || iconMap.shield}/></svg>
                </div>
                <span class="text-5xl font-headline font-black text-white/5 group-hover:text-primary/20 transition-colors">{String(i + 1).padStart(2, '0')}</span>
              </div>
              <h3 class="text-lg font-headline font-black uppercase text-white mb-3 group-hover:text-primary transition-colors">{feature.title}</h3>
              <p class="text-zinc-500 text-sm leading-relaxed">{feature.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Our Process -->
    <section class="py-16 md:py-24 bg-surface border-y border-white/5">
      <div class="container mx-auto px-6 md:px-12">
        <div class="text-center mb-16 reveal-on-scroll">
          <h2 class="text-4xl md:text-5xl font-headline font-black uppercase tracking-tighter text-white">Our <span class="text-primary">Process</span></h2>
          <p class="text-zinc-500 mt-4 uppercase tracking-[0.3em] font-headline text-label-xs font-bold">How We Work | From First Call to Completion</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 reveal-on-scroll">
          {content.steps.map((step, i) => (
            <div class="relative bg-zinc-950 border border-white/5 p-8 group hover:border-primary/30 transition-all duration-500">
              <div class="w-10 h-10 bg-primary text-white font-headline font-black text-sm flex items-center justify-center mb-6">{String(i + 1).padStart(2, '0')}</div>
              <h3 class="text-lg font-headline font-black uppercase text-white mb-3">{step.title}</h3>
              <p class="text-zinc-500 text-sm leading-relaxed">{step.desc}</p>
              {i < content.steps.length - 1 && (
                <div class="hidden lg:block absolute top-1/2 -right-3 transform -translate-y-1/2 text-zinc-700 z-10">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
                </div>
              )}
              <div class="h-1 w-full bg-white/5 overflow-hidden mt-6">
                <div class="h-full bg-primary w-0 group-hover:w-full transition-all duration-700"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Trust Stats Bar -->
    <section class="bg-primary py-12 md:py-16">
      <div class="container mx-auto px-6 md:px-12">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12 text-center">
          {content.stats.map((stat) => (
            <div>
              <p class="text-4xl md:text-5xl font-headline font-black text-white">{stat.value}</p>
              <p class="text-sm font-bold uppercase tracking-widest text-white/70 mt-2">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Choose Mana -->
    <section class="py-16 md:py-24 bg-zinc-900">
      <div class="container mx-auto px-6 md:px-12">
        <h2 class="text-3xl md:text-5xl font-headline font-black uppercase mb-12 reveal-on-scroll">Why Canterbury Trusts <span class="text-primary">Mana</span></h2>
        <div class="grid md:grid-cols-3 gap-8 reveal-on-scroll">
          <div class="bg-black/60 p-10 border border-white/5 group hover:border-primary/50 transition-all">
            <div class="w-14 h-14 bg-primary/10 rounded-sm flex items-center justify-center mb-6 text-primary flex-shrink-0">
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
            </div>
            <h3 class="text-xl font-headline font-black uppercase text-white mb-3">Fully Compliant</h3>
            <p class="text-zinc-500 text-sm leading-relaxed">All work meets NZ health and safety regulations, building codes, and engineering certification requirements. Complete documentation provided.</p>
          </div>
          <div class="bg-black/60 p-10 border border-white/5 group hover:border-primary/50 transition-all">
            <div class="w-14 h-14 bg-primary/10 rounded-sm flex items-center justify-center mb-6 text-primary flex-shrink-0">
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            </div>
            <h3 class="text-xl font-headline font-black uppercase text-white mb-3">Safety First</h3>
            <p class="text-zinc-500 text-sm leading-relaxed">Zero incident commitment with comprehensive safety protocols, Site Safe qualified teams, and ongoing inspection compliance.</p>
          </div>
          <div class="bg-black/60 p-10 border border-white/5 group hover:border-primary/50 transition-all">
            <div class="w-14 h-14 bg-primary/10 rounded-sm flex items-center justify-center mb-6 text-primary flex-shrink-0">
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24"><path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
            </div>
            <h3 class="text-xl font-headline font-black uppercase text-white mb-3">Fast Quote</h3>
            <p class="text-zinc-500 text-sm leading-relaxed">Detailed quotation within 24 hours. No hidden costs, transparent pricing with full scope coverage.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    {(service.data.faq || []).length > 0 && (
      <section class="py-16 md:py-24 bg-background border-t border-white/5" id="faq">
        <div class="container mx-auto px-6 md:px-12 max-w-4xl">
          <div class="text-center mb-16 reveal-on-scroll">
            <h2 class="text-4xl md:text-5xl font-headline font-black uppercase tracking-tighter text-white">Common <span class="text-primary">Questions</span></h2>
            <p class="text-zinc-500 mt-4 uppercase tracking-[0.3em] font-headline text-label-xs font-bold">{type} Scaffolding | Expert Answers</p>
          </div>
          <div class="space-y-4 reveal-on-scroll">
            {(service.data.faq || []).map((item) => (
              <details class="group bg-surface border border-white/5 hover:border-white/10 transition-colors">
                <summary class="flex items-center justify-between p-6 cursor-pointer select-none list-none">
                  <h3 class="text-base md:text-lg font-headline font-bold text-white pr-4">{item.question}</h3>
                  <span class="text-primary text-2xl font-bold transition-transform group-open:rotate-45 flex-shrink-0">+</span>
                </summary>
                <div class="px-6 pb-6 border-t border-white/5">
                  <p class="text-zinc-400 leading-relaxed mt-4">{item.answer}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- CTA Section -->
    <section class="py-20 md:py-32 bg-zinc-950 border-t border-white/5 relative overflow-hidden">
      <div class="scaffolding-grid-bg absolute inset-0 pointer-events-none"></div>
      <div class="container mx-auto px-6 md:px-12 relative z-10 text-center">
        <div class="reveal-on-scroll">
          <h2 class="text-4xl md:text-6xl font-headline font-black uppercase text-white tracking-tighter mb-6">
            Ready to Start Your <span class="text-primary">Project</span>?
          </h2>
          <p class="text-lg text-zinc-400 mb-10 max-w-2xl mx-auto">
            Get a free technical consultation and quote for your {type.toLowerCase()} scaffolding needs.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="bg-primary text-white font-headline font-black uppercase px-12 py-5 tracking-widest transition-all hover:bg-orange-600 border-b-4 border-orange-800 shadow-[0_4px_20px_rgba(212,68,28,0.4)]">
              Request Quote
            </a>
            <a href="/services" class="border-2 border-white text-white font-headline font-black uppercase px-12 py-5 tracking-widest transition-all hover:bg-white hover:text-black">
              View All Services
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Base>
