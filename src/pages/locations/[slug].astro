---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((location) => ({
    params: { slug: location.id.replace(/\.md$/, '') },
    props: { location },
  }));
}

const { location } = Astro.props;
const { Content } = await render(location);
const slug = location.id.replace(/\.md$/, '');

const locationImages = {
  'christchurch': '/images/Mana facebook pic.jpg',
  'rangiora-north-canterbury': '/images/N2.jpg',
  'selwyn-district': '/images/N4.jpg',
  'ashburton-mid-canterbury': '/images/N6.jpg',
};

const defaultImage = '/images/N1.jpg';
const heroImage = locationImages[slug] || defaultImage;
const ogImage = location.data.image || heroImage;
const canonicalURL = `https://manasastro.pages.dev/locations/${slug}`;
const siteUrl = 'https://manasastro.pages.dev';

const locationData: Record<string, {
  tagline: string;
  features: { icon: string; title: string; desc: string }[];
  areas: { name: string; spots: string[] }[];
  stats: { value: string; label: string }[];
}> = {
  'christchurch': {
    tagline: 'Our home ground, our strongest team',
    features: [
      { icon: 'map-pin', title: 'City-Wide Coverage', desc: 'Central city through to all suburbs — Belfast to Halswell, New Brighton to Riccarton. Full Christchurch coverage with no travel fees.' },
      { icon: 'heritage', title: 'Heritage Restoration', desc: 'Experienced with character homes and heritage-listed buildings. Non-invasive access systems that preserve historic fabric.' },
      { icon: 'seismic', title: 'Seismic-Aware Design', desc: 'TC1, TC2, TC3 ground conditions understood. Enhanced lateral bracing and foundation stability assessment for post-quake Christchurch.' },
      { icon: 'hills', title: 'Port Hills Access', desc: 'Lyttelton, Governors Bay, and steep suburban sections. Specialist hillside scaffolding with ground condition adaptation.' },
      { icon: 'commercial', title: 'CBD & Commercial', desc: 'Office towers, retail fit-outs, hospitality venues. Pedestrian protection, traffic management, and after-hours installation.' },
      { icon: 'rapid', title: 'Same-Day Response', desc: 'Christchurch-based yard means rapid mobilisation. Same-day site assessment available for urgent requirements.' },
    ],
    areas: [
      { name: 'Central City & Inner Suburbs', spots: ['CBD', 'Addington', 'Sydenham', 'Middleton'] },
      { name: 'Northern Corridor', spots: ['Belfast', 'Kaiapoi', 'Papanui', 'Northcote', 'Redwood'] },
      { name: 'Western Suburbs', spots: ['Riccarton', 'Ilam', 'Fendalton', 'Burnside', 'Harewood'] },
      { name: 'Eastern & Coastal', spots: ['New Brighton', 'Burwood', 'Parklands', 'Shirley'] },
      { name: 'Southern Hills', spots: ['Cashmere', 'Huntsbury', 'Halswell', 'Hornby'] },
      { name: 'Port Hills & Harbour', spots: ['Lyttelton', 'Governors Bay', 'Diamond Harbour'] },
    ],
    stats: [
      { value: '500+', label: 'Local Projects' },
      { value: '24hr', label: 'Quote Turnaround' },
      { value: '0', label: 'Safety Incidents' },
      { value: '100%', label: 'Compliance Rate' },
    ],
  },
  'rangiora-north-canterbury': {
    tagline: 'Supporting the fastest growing region in Canterbury',
    features: [
      { icon: 'growth', title: 'Development Support', desc: 'North Canterbury is booming. Multi-home subdivision access, phased installations, and developer program integration.' },
      { icon: 'home', title: 'Residential Specialists', desc: 'New builds in Pegasus, character homes in Kaiapoi, lifestyle blocks near Rangiora. Every home type covered.' },
      { icon: 'rural', title: 'Rural & Lifestyle', desc: 'Large-section homes, outbuildings, farm infrastructure. Access solutions for properties where standard setups don\'t fit.' },
      { icon: 'schedule', title: 'Efficient Scheduling', desc: 'Regular North Canterbury runs mean coordinated multi-project delivery. No wasted trips, no travel surcharges.' },
      { icon: 'trade', title: 'Builder Partnerships', desc: 'Working with North Canterbury\'s top builders. Schedule coordination, reliable timing, and competitive pricing.' },
      { icon: 'agriculture', title: 'Agricultural Access', desc: 'Dairy sheds, implement sheds, storage facilities. Purpose-built systems for rural infrastructure.' },
    ],
    areas: [
      { name: 'Rangiora', spots: ['Town Centre', 'Residential Developments', 'Lifestyle Blocks', 'Industrial'] },
      { name: 'Kaiapoi', spots: ['Town Centre', 'Riverside Properties', 'New Builds', 'Commercial'] },
      { name: 'Pegasus & Woodend', spots: ['New Subdivisions', 'Residential', 'Community Facilities'] },
      { name: 'Amberley & Hurunui', spots: ['Rural Residential', 'Agricultural', 'Community Buildings'] },
      { name: 'Oxford & Cust', spots: ['Rural Homes', 'Farm Buildings', 'Lifestyle Blocks'] },
    ],
    stats: [
      { value: '150+', label: 'Local Projects' },
      { value: '24-48hr', label: 'Quote Turnaround' },
      { value: '0', label: 'Travel Fees' },
      { value: '100%', label: 'Compliance Rate' },
    ],
  },
  'selwyn-district': {
    tagline: 'New Zealand\'s fastest growing district — we keep up',
    features: [
      { icon: 'subdivision', title: 'Subdivision Specialists', desc: 'Rolleston and Lincoln are among NZ\'s fastest-growing towns. Multi-home access programs with phased installation and progressive handover.' },
      { icon: 'industrial', title: 'Rolleston Industrial', desc: 'Business park construction, warehouse access, and commercial builds. Heavy-duty systems for industrial-scale projects.' },
      { icon: 'lifestyle', title: 'Lifestyle Property Experts', desc: 'West Melton, Prebbleton, and the Malvern Hills. Large homes, outbuildings, and multi-elevation access for big sections.' },
      { icon: 'agriculture', title: 'Agricultural Infrastructure', desc: 'Dairy sheds, processing facilities, equestrian centres. Purpose-built access for Canterbury\'s farming backbone.' },
      { icon: 'community', title: 'Community Projects', desc: 'Schools, community centres, and public facilities. Coordination with council requirements and public safety standards.' },
      { icon: 'logistics', title: 'No Travel Surcharges', desc: 'Regular Selwyn service runs keep costs down. Same competitive pricing you\'d get in Christchurch — no rural penalty.' },
    ],
    areas: [
      { name: 'Rolleston', spots: ['Industrial Parks', 'New Subdivisions', 'Commercial', 'Community'] },
      { name: 'Lincoln', spots: ['University Town', 'Residential', 'Research Facilities'] },
      { name: 'Prebbleton & Halswell', spots: ['Lifestyle Properties', 'New Builds', 'Commercial'] },
      { name: 'Darfield & Malvern', spots: ['Rural Residential', 'Agricultural', 'Community'] },
      { name: 'West Melton & Yaldhurst', spots: ['Lifestyle Blocks', 'Rural-Residential', 'Equestrian'] },
      { name: 'Leeston & Ellesmere', spots: ['Rural Communities', 'Agricultural', 'Residential'] },
    ],
    stats: [
      { value: '120+', label: 'Selwyn Projects' },
      { value: '24-48hr', label: 'Quote Turnaround' },
      { value: '0', label: 'Travel Fees' },
      { value: '100%', label: 'Compliance Rate' },
    ],
  },
  'ashburton-mid-canterbury': {
    tagline: 'Agricultural scaffolding with industrial precision',
    features: [
      { icon: 'dairy', title: 'Dairy Sector Expert', desc: 'Mid-Canterbury\'s dairy industry relies on us for shed maintenance, plant access, and seasonal shutdown support.' },
      { icon: 'processing', title: 'Processing Facilities', desc: 'Plant maintenance, equipment installation, and inspection systems for agricultural processing infrastructure.' },
      { icon: 'rural', title: 'Rural Infrastructure', desc: 'Irrigation systems, storage buildings, equipment sheds. Access solutions for every farm structure.' },
      { icon: 'residential', title: 'Town & Country Homes', desc: 'Ashburton residential through to remote rural properties. Ground condition flexibility and weather-aware planning.' },
      { icon: 'seasonal', title: 'Seasonal Scheduling', desc: 'Shutdown support, maintenance windows, and seasonal coordination. We work around your production calendar.' },
      { icon: 'remote', title: 'Remote Site Capability', desc: 'Methven, Rakaia, and beyond. Full logistics support for projects well outside Christchurch — no site too far.' },
    ],
    areas: [
      { name: 'Ashburton', spots: ['Town Centre', 'Industrial Areas', 'Residential', 'Agricultural Processing'] },
      { name: 'Rakaia & Tinwald', spots: ['Rural Residential', 'Agricultural', 'Industrial'] },
      { name: 'Methven & Mount Hutt', spots: ['Rural Homes', 'Tourism Facilities', 'Lifestyle Blocks'] },
      { name: 'Wakanui & Rural', spots: ['Farm Buildings', 'Rural Homes', 'Agricultural Infrastructure'] },
    ],
    stats: [
      { value: '80+', label: 'Mid-Canterbury Projects' },
      { value: '48hr', label: 'Quote Turnaround' },
      { value: '0', label: 'Travel Fees' },
      { value: '100%', label: 'Compliance Rate' },
    ],
  },
};

const content = locationData[slug] || locationData['christchurch'];

const iconMap: Record<string, string> = {
  'map-pin': 'M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z',
  'heritage': 'M12 2L2 12h3v8h14v-8h3L12 2zm-2 10H8v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2zm-4 8h-2v-4h2v4z',
  'seismic': 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z',
