---
import Base from '../../layouts/Base.astro';
import BrandedImage from '../../components/BrandedImage.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  return blogPosts.map((post) => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const specificImages: Record<string, string> = {
  '01-scaffolding-safety-standards-nz': '/images/blog/safety-standards-nz.jpg',
  '02-residential-vs-commercial-scaffolding': '/images/blog/residential-vs-commercial.jpg',
  '03-industrial-scaffolding-challenges': '/images/blog/industrial-challenges.jpg',
  '04-scaffolding-costs-guide': '/images/blog/costs-guide.jpg',
  '05-seismic-scaffolding-christchurch': '/images/blog/seismic-christchurch.jpg',
  'cantilever-scaffolding-solutions': '/images/blog/cantilever-solutions.jpg',
  '5-signs-better-access-solutions': '/images/blog/access-solutions.jpg',
  'choosing-right-scaffolding-system': '/images/blog/choosing-right-system.jpg',
  'commercial-facade-restoration-case-study': '/images/blog/facade-restoration.jpg',
  'construction-site-safety-scaffolding': '/images/blog/construction-safety.jpg',
  'diy-scaffolding-safety-guide': '/images/blog/diy-safety-guide.jpg',
  'industrial-scaffolding-challenges': '/images/blog/industrial-challenges-2.jpg',
  'residential-vs-commercial-scaffolding': '/images/blog/residential-commercial-2.jpg',
  'scaffold-inspection-requirements': '/images/blog/inspection-requirements.jpg',
  'scaffolding-for-different-trades': '/images/blog/different-trades.jpg',
  'scaffolding-hire-costs-canterbury': '/images/blog/hire-costs-canterbury.jpg',
  'scaffolding-insurance-coverage': '/images/blog/insurance-coverage.jpg',
  'scaffolding-modifications-during-project': '/images/blog/modifications-project.jpg',
  'scaffolding-timeline-planning': '/images/blog/timeline-planning.jpg',
  'scaffolding-for-roof-work': '/images/blog/roof-work.jpg',
  'scaffolding-weather-management': '/images/blog/weather-management.jpg',
  'site-preparation-scaffolding-installation': '/images/blog/site-preparation.jpg',
  'true-cost-scaffolding-accidents': '/images/blog/accident-costs.jpg',
  'winter-scaffolding-preparation': '/images/blog/winter-preparation.jpg',
  'working-at-height-options': '/images/blog/height-options.jpg',
  'seismic-scaffolding-christchurch': '/images/blog/seismic-engineering.jpg',
};

const categoryImages: Record<string, string> = {
  'Safety': '/images/blog/safety.svg',
  'Guide': '/images/blog/guide.svg',
  'Costs': '/images/blog/costs.svg',
  'Industrial': '/images/blog/industrial.svg',
  'Residential': '/images/blog/residential.svg',
  'Commercial': '/images/blog/commercial.svg',
  'Planning': '/images/blog/planning.svg',
  'Weather': '/images/blog/weather.svg',
  'Inspection': '/images/blog/inspection.svg',
  'Seismic': '/images/blog/seismic.svg',
  'Access': '/images/blog/access.svg',
  'Roof': '/images/blog/roof.svg',
  'Technical': '/images/blog/guide.svg',
};

function getImageForPost(post: any): string {
  const postId = post.id.replace(/\.md$/, '');
  if (specificImages[postId]) return specificImages[postId];
  if (categoryImages[post.data.category]) return categoryImages[post.data.category];
  return categoryImages['Safety'];
}

const featuredImage = getImageForPost(post);
const canonicalURL = `https://mana-scaffolding.pages.dev/blog/${post.id.replace(/\.md$/, '')}`;
const readingTime = Math.max(3, Math.ceil((post.data.description.split(/\s+/).length + 800) / 200));

const tocHeadings = (headings || []).filter((h: any) => h.depth >= 2 && h.depth <= 3);

const allPosts = await getCollection('blog');
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .filter((p) => {
    const sharedTags = p.data.tags.filter((t: string) => post.data.tags.includes(t));
    return sharedTags.length > 0 || p.data.category === post.data.category;
  })
  .sort((a: any, b: any) => {
    const aShared = a.data.tags.filter((t: string) => post.data.tags.includes(t)).length;
    const bShared = b.data.tags.filter((t: string) => post.data.tags.includes(t)).length;
    return bShared - aShared;
  })
  .slice(0, 3);
---

<Base 
  title={post.data.title} 
  description={post.data.description}
  image={featuredImage}
  canonicalURL={canonicalURL}
  hideSidebar={true}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "image": `https://mana-scaffolding.pages.dev${featuredImage}`,
    "datePublished": post.data.pubDate.toISOString(),
    "dateModified": post.data.updatedDate ? post.data.updatedDate.toISOString() : post.data.pubDate.toISOString(),
    "author": {
      "@type": "Organization",
      "name": post.data.author,
      "url": "https://mana-scaffolding.pages.dev"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Mana Scaffolding Limited",
      "logo": {
        "@type": "ImageObject",
        "url": "https://mana-scaffolding.pages.dev/logos/Mana-Scaffolding-Logo.png",
        "width": 600,
        "height": 60
      }
    },
    "articleSection": post.data.category,
    "inLanguage": "en-NZ",
    "wordCount": readingTime * 200,
    "timeRequired": `PT${readingTime}M`
  })} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mana-scaffolding.pages.dev" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://mana-scaffolding.pages.dev/blog" },
      { "@type": "ListItem", "position": 3, "name": post.data.title, "item": canonicalURL }
    ]
  })} />
  
  <div id="reading-progress" class="fixed top-0 left-0 h-[3px] bg-primary z-[200] transition-all duration-150 ease-out" style="width: 0%"></div>

  <main id="main-content" class="pt-24 pb-16">
    <article class="bg-background">
      <!-- Breadcrumb -->
      <div class="border-b border-white/5 bg-surface">
        <div class="container mx-auto px-6 max-w-4xl py-3">
          <nav class="flex items-center gap-2 text-xs font-headline uppercase tracking-widest">
            <a href="/" class="text-zinc-500 hover:text-primary transition-colors">Home</a>
            <span class="text-zinc-700">/</span>
            <a href="/blog" class="text-zinc-500 hover:text-primary transition-colors">Blog</a>
            <span class="text-zinc-700">/</span>
            <span class="text-zinc-400 truncate max-w-xs">{post.data.title}</span>
          </nav>
        </div>
      </div>

      <!-- Featured Image -->
      <div class="relative w-full h-64 md:h-[420px] lg:h-[480px] overflow-hidden">
        <BrandedImage 
          src={featuredImage} 
          alt={post.data.title}
          logoPosition="bottom-right"
          logoOpacity={0.75}
          logoSize="medium"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-background via-background/60 to-transparent pointer-events-none" />
        <div class="absolute inset-0 bg-gradient-to-r from-background/40 to-transparent pointer-events-none" />
      </div>

      <!-- Article Content -->
      <div class="container mx-auto px-6 max-w-4xl">
        <!-- Article Header -->
        <header class="mb-12 -mt-32 relative z-10">
          <div class="bg-surface/95 backdrop-blur-md border border-white/5 p-8 md:p-12">
            <div class="flex items-center gap-3 mb-6">
              <span class="text-label-xs font-bold text-primary uppercase tracking-widest bg-primary/10 border border-primary/20 px-3 py-1">{post.data.category}</span>
              <span class="text-zinc-700">|</span>
              <time datetime={post.data.pubDate.toISOString()} class="text-label-xs text-zinc-500">
                {post.data.pubDate.toLocaleDateString('en-NZ', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span class="text-zinc-700">|</span>
              <span class="text-label-xs text-zinc-500">{readingTime} min read</span>
            </div>
            <h1 class="text-3xl md:text-5xl font-headline font-black uppercase tracking-tighter text-white mb-6 leading-tight">
              {post.data.title}
            </h1>
            <p class="text-lg md:text-xl text-zinc-400 leading-relaxed mb-8">
              {post.data.description}
            </p>
            <div class="flex items-center gap-4 pt-6 border-t border-white/5">
              <div class="h-12 w-12 bg-primary/10 border border-primary/20 flex items-center justify-center">
                <span class="text-primary font-headline font-black text-lg">{post.data.author.charAt(0)}</span>
              </div>
              <div>
                <p class="text-white font-headline font-bold text-sm">{post.data.author}</p>
                <p class="text-zinc-500 text-xs uppercase tracking-wider">Mana Scaffolding Limited</p>
              </div>
            </div>
          </div>
        </header>
        
        <!-- Table of Contents -->
        {tocHeadings.length > 2 && (
          <nav class="mb-12 reveal-on-scroll">
            <div class="bg-surface border border-white/5 overflow-hidden">
              <div class="bg-primary/10 border-b border-primary/20 px-6 md:px-8 py-3 flex items-center gap-3">
                <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>
                <span class="text-label-xs font-bold text-primary uppercase tracking-widest">Contents</span>
              </div>
              <div class="p-6 md:p-8">
                <ol class="space-y-1">
                  {tocHeadings.map((heading: any, i: number) => (
                    <li class={heading.depth === 3 ? 'ml-8' : ''}>
                      <a 
                        href={`#${heading.slug}`} 
                        class="text-zinc-400 hover:text-primary transition-colors text-sm leading-relaxed flex items-start gap-3 py-1.5 border-b border-white/[0.03] last:border-0 hover:border-primary/20 group"
                      >
                        {heading.depth === 2 && (
                          <span class="text-zinc-700 group-hover:text-primary font-headline font-bold text-xs mt-0.5 tabular-nums">{String(i + 1).padStart(2, '0')}</span>
                        )}
                        {heading.depth === 3 && (
                          <span class="text-primary/30 text-xs mt-0.5">—</span>
                        )}
                        <span class="group-hover:text-white transition-colors">{heading.text}</span>
                      </a>
                    </li>
                  ))}
                </ol>
              </div>
            </div>
          </nav>
        )}
        
        <!-- Article Body -->
        <div class="prose max-w-none reveal-on-scroll">
          <Content />
        </div>

        <!-- Inline CTA -->
        <div class="my-16 reveal-on-scroll">
          <div class="bg-surface border border-white/5 p-8 md:p-10 text-center">
            <p class="text-zinc-500 text-sm uppercase tracking-widest font-headline font-bold mb-4">Need Expert Scaffolding?</p>
            <p class="text-white text-lg mb-6">Get a free consultation for your next project.</p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a 
                href="/contact" 
                class="bg-primary text-white font-headline font-black uppercase px-8 py-4 tracking-widest hover:bg-orange-600 transition-colors border-b-4 border-orange-800 text-sm"
              >
                Get a Quote
              </a>
              <a 
                href="tel:0508626272" 
                class="border-2 border-white/20 text-white font-headline font-bold uppercase px-8 py-4 tracking-widest hover:border-primary hover:text-primary transition-colors text-sm"
              >
                Call: 0508 626 272
              </a>
            </div>
          </div>
        </div>
        
        <!-- Tags & Share -->
        <div class="border-t border-white/5 pt-8 reveal-on-scroll">
          <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag: string) => (
                <span class="text-label-xs uppercase tracking-widest bg-white/5 border border-white/5 px-4 py-2 text-zinc-400 hover:border-primary/30 hover:text-primary transition-colors cursor-default">#{tag}</span>
              ))}
            </div>
            <div class="flex items-center gap-4">
              <span class="text-zinc-600 text-xs uppercase tracking-widest font-headline">Share</span>
              <a 
                href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(canonicalURL)}&title=${encodeURIComponent(post.data.title)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-zinc-500 hover:text-primary transition-colors"
                aria-label="Share on LinkedIn"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              </a>
              <a 
                href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalURL)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-zinc-500 hover:text-primary transition-colors"
                aria-label="Share on Facebook"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <button 
                onclick="navigator.clipboard.writeText(window.location.href).then(() => { this.textContent = 'Copied!'; setTimeout(() => { this.innerHTML = '<svg class=&quot;w-5 h-5&quot; fill=&quot;none&quot; stroke=&quot;currentColor&quot; viewBox=&quot;0 0 24 24&quot;><path stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot; stroke-width=&quot;2&quot; d=&quot;M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z&quot;/></svg>'; }, 2000); })"
                class="text-zinc-500 hover:text-primary transition-colors"
                aria-label="Copy link"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              </button>
            </div>
          </div>
        </div>

        <!-- Author Bio -->
        <div class="mt-12 p-6 md:p-8 bg-surface border border-white/5 reveal-on-scroll">
          <div class="flex flex-col sm:flex-row gap-6 items-start">
            <div class="h-16 w-16 bg-primary/10 border border-primary/20 flex items-center justify-center flex-shrink-0">
              <span class="text-primary font-headline font-black text-2xl">{post.data.author.charAt(0)}</span>
            </div>
            <div>
              <p class="text-white font-headline font-black text-lg uppercase tracking-tight">{post.data.author}</p>
              <p class="text-primary text-xs uppercase tracking-widest font-bold mb-3">Mana Scaffolding Limited</p>
              <p class="text-zinc-400 text-sm leading-relaxed">
                Based in Christchurch, Mana Scaffolding brings international expertise from Canada and the UK to deliver safe, compliant scaffolding solutions across Canterbury. Contact us at 0508 626 272.
              </p>
            </div>
          </div>
        </div>

        <!-- Related Articles -->
        {relatedPosts.length > 0 && (
          <section class="mt-16 pt-12 border-t border-white/5 reveal-on-scroll">
            <div class="flex items-center gap-3 mb-8">
              <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              <h2 class="text-sm font-headline font-bold uppercase tracking-widest text-primary">Related Articles</h2>
            </div>
            <div class="grid md:grid-cols-3 gap-6">
              {relatedPosts.map((relPost: any) => (
                <a href={`/blog/${relPost.id.replace(/\.md$/, '')}`} class="block group">
                  <article class="bg-surface border border-white/5 p-6 h-full hover:border-primary/30 transition-all duration-300">
                    <span class="text-label-xs font-bold text-primary uppercase tracking-widest">{relPost.data.category}</span>
                    <h3 class="text-sm font-headline font-black uppercase text-white mt-2 mb-2 group-hover:text-primary transition-colors line-clamp-2 leading-snug">
                      {relPost.data.title}
                    </h3>
                    <p class="text-zinc-500 text-xs leading-relaxed line-clamp-2">{relPost.data.description}</p>
                  </article>
                </a>
              ))}
            </div>
          </section>
        )}
        
        <!-- Back to Blog -->
        <div class="mt-12 pt-8 border-t border-white/5">
          <a href="/blog" class="inline-flex items-center gap-2 text-primary hover:text-orange-600 transition-colors font-headline font-bold uppercase tracking-widest text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Back to all articles
          </a>
        </div>
      </div>
    </article>
  </main>
</Base>

<script>
  function initReadingProgress() {
    const progressBar = document.getElementById('reading-progress');
    if (!progressBar) return;

    function updateProgress() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      progressBar.style.width = `${Math.min(100, progress)}%`;
    }

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }

  function initSmoothScroll() {
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function(e) {
        e.preventDefault();
        const target = document.querySelector(this.getAttribute('href'));
        if (target) {
          const offset = 100;
          const position = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top: position, behavior: 'smooth' });
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    initReadingProgress();
    initSmoothScroll();
  });
  document.addEventListener('astro:after-swap', () => {
    initReadingProgress();
    initSmoothScroll();
  });
  if (document.readyState !== 'loading') {
    initReadingProgress();
    initSmoothScroll();
  }
</script>

<style>
  .prose h2, .prose h3, .prose h4 {
    scroll-margin-top: 100px;
  }
</style>
