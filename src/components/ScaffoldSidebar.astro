---
---

<div id="scaffold-sidebar" class="hidden md:flex" aria-hidden="true">
  <div id="scaffold-mast" class="scaffold-vertical"></div>
  <div class="scaffold-progress-label">
    <span>Structural</span>
    <span>Integrity</span>
  </div>
</div>

<style>
  #scaffold-sidebar {
    width: 60px;
    position: fixed;
    right: 0;
    top: 0;
    height: 100vh;
    z-index: 100;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 0;
    pointer-events: none;
  }

  .scaffold-vertical {
    width: 4px;
    background: linear-gradient(90deg, #333, #666, #333);
    height: 100%;
    position: relative;
    box-shadow: 2px 0 5px rgba(0,0,0,0.5);
  }

  .scaffold-segment {
    position: absolute;
    left: -8px;
    width: 20px;
    height: 4px;
    background: #D4441C;
    opacity: 0;
    transform: translateX(100px);
    transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 0 15px rgba(212, 68, 28, 0.8);
  }

  .scaffold-segment.active {
    opacity: 1;
    transform: translateX(0);
  }

  .coupler {
    position: absolute;
    left: -4px;
    width: 12px;
    height: 12px;
    background: #888;
    border-radius: 2px;
    border: 1px solid #444;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .coupler.active {
    opacity: 1;
  }

  .scaffold-progress-label {
    position: absolute;
    bottom: 8%;
    right: 8px;
    font-size: 9px;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #D4441C;
    transform: rotate(90deg);
    opacity: 0.5;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }
  
  .scaffold-progress-label span {
    white-space: nowrap;
  }
</style>

<script>
  const mast = document.getElementById('scaffold-mast');
  const segmentsCount = 20;
  
  if (mast) {
    for (let i = 0; i < segmentsCount; i++) {
      const seg = document.createElement('div');
      seg.className = 'scaffold-segment';
      seg.style.top = `${(i / segmentsCount) * 100}%`;
      
      const coupler = document.createElement('div');
      coupler.className = 'coupler';
      coupler.style.top = `${(i / segmentsCount) * 100}%`;
      
      mast.appendChild(seg);
      mast.appendChild(coupler);
    }
    
    const segments = document.querySelectorAll('.scaffold-segment');
    const couplers = document.querySelectorAll('.coupler');
    
    function handleScroll() {
      const scrollPercent = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
      const activeIdx = Math.floor(scrollPercent * segmentsCount);
      
      segments.forEach((seg, idx) => {
        if (idx <= activeIdx) seg.classList.add('active');
        else seg.classList.remove('active');
      });
      
      couplers.forEach((cup, idx) => {
        if (idx <= activeIdx) cup.classList.add('active');
        else cup.classList.remove('active');
      });
    }
    
    window.addEventListener('scroll', handleScroll);
    handleScroll();
  }
</script>