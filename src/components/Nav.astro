---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/locations', label: 'Locations' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---

<nav class="fixed top-0 w-full z-50 bg-background/80 backdrop-blur-xl border-b border-white/5 px-6 py-4 flex justify-between items-center" aria-label="Main navigation">
  <a href="/" class="flex items-center gap-3" aria-label="Mana Scaffolding Home">
    <img alt="Mana Scaffolding Logo" class="h-10 md:h-12 w-auto object-contain" src="/logos/Mana-Scaffolding-Logo.png" width="200" height="48" />
  </a>
  
  <!-- Desktop nav -->
  <div class="hidden lg:flex gap-8">
    {navLinks.map((link) => (
      <a class="text-label font-headline font-black hover:text-primary transition-colors" href={link.href}>
        {link.label}
      </a>
    ))}
  </div>
  
  <!-- Phone CTA (always visible) -->
  <div class="flex items-center gap-4">
    <a class="text-xs font-headline font-black bg-primary px-5 py-2.5 rounded-sm text-white tracking-widest hover:bg-orange-600 transition-colors shadow-lg hidden sm:inline-block" href="tel:0508626272">
      0508 626 272
    </a>
    
    <!-- Mobile hamburger button - icon only -->
    <button 
      id="mobile-menu-toggle" 
      class="lg:hidden w-12 h-12 flex items-center justify-center text-white hover:text-primary transition-colors z-50 !p-0 !border-0 !bg-transparent" 
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      type="button"
    >
      <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
      </svg>
    </button>
  </div>
</nav>

<!-- Mobile menu overlay -->
<div id="mobile-menu" class="fixed inset-0 z-40 bg-background hidden lg:hidden" aria-hidden="true">
  <div class="flex flex-col h-full pt-20 px-6">
    <div class="flex flex-col gap-6">
      {navLinks.map((link) => (
        <a class="text-2xl font-headline font-black uppercase text-white hover:text-primary transition-colors" href={link.href}>
          {link.label}
        </a>
      ))}
    </div>
    
    <div class="mt-auto pb-8">
      <a class="inline-block text-lg font-headline font-black bg-primary px-8 py-4 text-white tracking-widest hover:bg-orange-600 transition-colors" href="tel:0508626272">
        Call: 0508 626 272
      </a>
    </div>
  </div>
</div>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      toggle.setAttribute('aria-expanded', String(isOpen));
      menu.setAttribute('aria-hidden', String(!isOpen));
      
      const icon = toggle.querySelector('.material-symbols-outlined');
      if (icon) {
        icon.textContent = isOpen ? 'close' : 'menu';
      }
    });
    
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        const icon = toggle.querySelector('.material-symbols-outlined');
        if (icon) icon.textContent = 'menu';
      });
    });
  }
</script>