---
export interface Props {
  src: string;
  alt: string;
  class?: string;
  logoPosition?: 'bottom-right' | 'bottom-left' | 'top-right' | 'top-left';
  logoOpacity?: number;
  logoSize?: 'small' | 'medium' | 'large';
}

const { 
  src, 
  alt, 
  class = '',
  logoPosition = 'bottom-right',
  logoOpacity = 0.8,
  logoSize = 'medium'
} = Astro.props;

const sizeClasses = {
  small: 'h-6 w-auto md:h-8',
  medium: 'h-8 w-auto md:h-10',
  large: 'h-10 w-auto md:h-12'
};
---

<div class="relative inline-block group {class} overflow-hidden">
  <img 
    src={src} 
    alt={alt}
    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 scroll-color"
    loading="lazy"
  />
  <div 
    class="absolute p-2 md:p-3 transition-opacity duration-300"
    class:list={[
      `opacity-${(logoOpacity * 100).toFixed(0)}`,
      'group-hover:opacity-100',
      logoPosition === 'bottom-right' && 'bottom-0 right-0',
      logoPosition === 'bottom-left' && 'bottom-0 left-0',
      logoPosition === 'top-right' && 'top-0 right-0',
      logoPosition === 'top-left' && 'top-0 left-0',
    ]}
  >
    <img 
      src="/logos/Mana-Scaffolding-Logo.png" 
      alt="Mana Scaffolding"
      class={sizeClasses[logoSize]}
      loading="lazy"
    />
  </div>
</div>
