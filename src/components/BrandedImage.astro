---
import type { ImageMetadata } from 'astro';

export interface Props {
  src: string | ImageMetadata;
  alt: string;
  class?: string;
  logoPosition?: 'bottom-right' | 'bottom-left' | 'top-right' | 'top-left';
  logoOpacity?: number;
  logoSize?: 'small' | 'medium' | 'large';
  eager?: boolean;
  widths?: number[];
  sizes?: string;
}

const { 
  src, 
  alt, 
  class: className = '',
  logoPosition = 'bottom-right',
  logoOpacity = 0.8,
  logoSize = 'medium',
  eager = false,
} = Astro.props;

const isOptimized = typeof src !== 'string';
const imageSrc = isOptimized ? (src as ImageMetadata).src : (src as string);

const loadingAttr = eager ? 'eager' : 'lazy';
const fetchpriorityAttr = eager ? 'high' : undefined;

const positionClasses = {
  'bottom-right': 'bottom-0 right-0',
  'bottom-left': 'bottom-0 left-0',
  'top-right': 'top-0 right-0',
  'top-left': 'top-0 left-0',
};

const logoSizeClasses = {
  small: 'h-6 w-auto md:h-8',
  medium: 'h-8 w-auto md:h-10',
  large: 'h-10 w-auto md:h-12'
};
---

<div class:list={['relative w-full h-full group overflow-hidden', className]}>
  <img
    src={imageSrc}
    alt={alt}
    class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105 scroll-color"
    loading={loadingAttr}
    {fetchpriorityAttr}
    decoding="async"
  />
  <div
    class:list={[
      'absolute p-2 md:p-3 transition-opacity duration-300 group-hover:opacity-100',
      `opacity-${(logoOpacity * 100).toFixed(0)}`,
      positionClasses[logoPosition],
    ]}
  >
    <img
      src="/logos/Mana-Scaffolding-Logo.png"
      alt="Mana Scaffolding"
      class={logoSizeClasses[logoSize]}
      loading="lazy"
      decoding="async"
    />
  </div>
</div>
