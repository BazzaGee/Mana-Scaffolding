---
export interface Props {
  sidebar?: boolean;
}

const { sidebar = false } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/locations', label: 'Locations' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
  { href: '/privacy', label: 'Privacy' },
];
---

<footer class={`bg-black border-t border-white/5 py-16 ${sidebar ? 'pr-0 md:pr-[70px]' : ''}`} role="contentinfo">
  <div class="container mx-auto px-6 md:px-12">
    <div class="flex flex-col lg:flex-row justify-between items-center gap-12">
      <div class="text-center lg:text-left">
        <img alt="Mana Scaffolding Logo" class="h-12 w-auto mb-6 mx-auto lg:mx-0" src="/logos/Mana-Scaffolding-Logo.png" width="200" height="48" loading="lazy" />
        <p class="text-xs text-zinc-600 uppercase font-bold tracking-[0.2em]">
          &copy; 2026 Mana Scaffolding Ltd. <br class="md:hidden"/> Christchurch, New Zealand.
        </p>
      </div>
      <nav class="flex flex-wrap justify-center gap-8 md:gap-16" aria-label="Footer navigation">
        {navLinks.map((link) => (
          <a class="text-label-xs font-headline font-bold uppercase text-zinc-500 hover:text-primary transition-colors" href={link.href}>
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>